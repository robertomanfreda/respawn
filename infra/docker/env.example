# Respawn HTTP server.
APP_HOST=0.0.0.0
APP_PORT=8080

# Database used by Respawn.
DATABASE_URL=postgresql+asyncpg://respawn:respawn@postgres:5432/respawn

# Model provider and default model.
MODEL_BACKEND=ollama
OLLAMA_BASE_URL=http://ollama:11434/v1
# Used by the Ollama server and by the Compose preload request.
# Use -1 to keep the model loaded indefinitely.
OLLAMA_KEEP_ALIVE=-1
# Use "ollama-data" for a Docker volume, or a host path such as /usr/share/ollama/.ollama.
OLLAMA_MODELS_PATH=ollama-data
DEFAULT_MODEL=gpt-oss:120b
# Optional vision preload: keep one Ollama backend, but preload a small vision model
# for image-input validation. Respawn still defaults to DEFAULT_MODEL
# unless a request explicitly selects another model.
VISION_MODEL=moondream:latest
# Keep the text and small vision smoke-test models loaded for the full benchmark.
OLLAMA_PRELOAD_MODELS=gpt-oss:120b,moondream:latest
MODEL_CAPABILITIES=gpt-oss:120b=text,file-text,reasoning,tools;moondream:latest=text,file-text,vision
MULTIMODAL_DOWNLOAD_TIMEOUT_SECONDS=10
MULTIMODAL_MAX_IMAGE_BYTES=5000000
MULTIMODAL_MAX_FILE_BYTES=2000000

# Local development auth.
AUTH_DISABLED=true
LOCAL_OPENAI_API_KEYS=local-dev-key:tenant-local

# Response storage.
STORE_DEFAULT=true
MAX_CHAIN_DEPTH=50
CONTEXT_WINDOW_DEFAULT_TOKENS=131072
MODEL_CONTEXT_WINDOWS=gpt-oss:120b=131072;gpt-oss-120b=131072;gpt-oss:20b=131072;gpt-oss-20b=131072;moondream:latest=4096
CONTEXT_TOKEN_MARGIN=256

# Local Responses prompt-cache accounting.
PROMPT_CACHE_ENABLED=true
PROMPT_CACHE_MIN_TOKENS=1024
PROMPT_CACHE_MAX_ENTRIES=256
PROMPT_CACHE_IN_MEMORY_TTL_SECONDS=3600
PROMPT_CACHE_EXTENDED_TTL_SECONDS=86400
PROMPT_CACHE_CHUNK_TOKENS=128

# Optional local Responses web_search execution.
WEB_SEARCH_ENABLED=false
WEB_SEARCH_BACKEND=searxng
WEB_SEARCH_BASE_URL=http://searxng:8080
WEB_SEARCH_TIMEOUT_SECONDS=10
WEB_SEARCH_MAX_RESULTS=5
WEB_SEARCH_MAX_RESULT_CHARS=12000
WEB_SEARCH_CACHE_TTL_SECONDS=3600
WEB_SEARCH_ALLOWED_DOMAINS=
WEB_SEARCH_BLOCKED_DOMAINS=
WEB_SEARCH_USER_AGENT=RespawnWebSearch/1.0

# Optional local Responses image_generation execution.
# Respawn defaults to ComfyUI. The model must exist in ComfyUI's
# models/checkpoints directory; Respawn does not download checkpoints itself.
IMAGE_GENERATION_ENABLED=false
IMAGE_GENERATION_BACKEND=comfyui
IMAGE_GENERATION_BASE_URL=http://comfyui:8188
IMAGE_GENERATION_MODEL=sd-v1-5.safetensors
IMAGE_GENERATION_TIMEOUT_SECONDS=180
IMAGE_GENERATION_DEFAULT_SIZE=512x512
IMAGE_GENERATION_MAX_PIXELS=1048576
IMAGE_GENERATION_DEFAULT_STEPS=8
IMAGE_GENERATION_MAX_STEPS=30
IMAGE_GENERATION_DEFAULT_CFG_SCALE=7
IMAGE_GENERATION_SAMPLER=Euler a
IMAGE_GENERATION_NEGATIVE_PROMPT=
IMAGE_GENERATION_OUTPUT_FORMAT=png

# Optional ComfyUI container used by the Compose image-generation profile.
# This is opt-in because the Docker image, Python dependencies, and checkpoint
# downloads/manual copies are large. The default base image is multi-arch and
# works for ARM64/GB10 hosts.
COMFYUI_REPOSITORY=https://github.com/Comfy-Org/ComfyUI.git
COMFYUI_REF=master
COMFYUI_PORT_HOST=8188
COMFYUI_DATA_PATH=comfyui-data
COMFYUI_BASE_DIRECTORY=/data
COMFYUI_DATABASE_URL=
COMFYUI_LISTEN=0.0.0.0
COMFYUI_PORT=8188
COMFYUI_ARGS=--disable-api-nodes --disable-pinned-memory --force-fp16 --fp16-vae --fp16-text-enc --dont-upcast-attention

# Model and streaming timeouts.
BACKEND_TIMEOUT_SECONDS=120
BACKGROUND_JOB_TIMEOUT_SECONDS=300
BACKGROUND_JOB_HEARTBEAT_SECONDS=1
STREAM_HEARTBEAT_SECONDS=15
MAX_OUTPUT_TOKENS_DEFAULT=2048

# Observability.
LOG_LEVEL=INFO
VICTORIA_METRICS_PORT=8428
# VictoriaMetrics retention period in months.
VICTORIA_RETENTION_PERIOD=1
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=respawn

# Benchmark runner.
RESPAWN_BENCHMARK_BASE_URL=http://respawn:8080
RESPAWN_BENCHMARK_API_KEY=local-dev-key
RESPAWN_BENCHMARK_SECONDARY_API_KEY=respawn-other-key
RESPAWN_BENCHMARK_API_KEYS=local-dev-key:tenant-local,respawn-other-key:tenant-other
RESPAWN_BENCHMARK_MODEL=gpt-oss:120b
RESPAWN_BENCHMARK_TEXT_MODEL=gpt-oss:120b
RESPAWN_BENCHMARK_VISION_MODEL=moondream:latest
RESPAWN_BENCHMARK_ASSET_BASE_URL=http://benchmark-assets:8000
RESPAWN_BENCHMARK_RUNS=3
RESPAWN_BENCHMARK_MAX_OUTPUT_TOKENS=64
RESPAWN_BENCHMARK_EXPECT_OLLAMA_METRICS=true
RESPAWN_BENCHMARK_INCLUDE_TAGS=
RESPAWN_BENCHMARK_EXCLUDE_TAGS=
RESPAWN_BENCHMARK_COVERAGE_GATE=true
RESPAWN_BENCHMARK_COMPARE_TO=

# Schema creation shortcut for local runs.
AUTO_CREATE_TABLES=true
